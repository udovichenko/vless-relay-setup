#!/bin/bash
# vpn — CLI для управления клиентами VPN на relay-сервере (issue #23)
# Команды: add / list / link / remove / help

set -euo pipefail

# Resolve real script path (через симлинк)
SCRIPT_REAL="$(readlink -f "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_REAL")" && pwd)"

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"
# shellcheck source=lib/3xui.sh
source "$SCRIPT_DIR/lib/3xui.sh"

XUI_DB="/etc/x-ui/x-ui.db"
INBOUND_TAG="inbound-443"
NAME_REGEX='^[a-zA-Z0-9_-]{1,32}$'

usage() {
    cat <<EOF
vpn — управление клиентами VPN на relay-сервере

Usage:
  vpn add <name>            создать клиента, напечатать ссылку на подписку
  vpn list                  таблица клиентов
  vpn link <name>           напечатать ссылку на подписку клиента
  vpn remove <name> [-f]    удалить клиента (с подтверждением; -f скипает)
  vpn help                  эта справка

<name>: [a-zA-Z0-9_-]{1,32}, должно быть уникальным
EOF
}

require_relay() {
    if [[ ! -f "$XUI_DB" ]]; then
        log_error "vpn CLI is for relay servers only ($XUI_DB not found)"
        exit 1
    fi
}

# Читает subURI из 3X-UI или конструирует из subDomain/subPort/subPath
get_subscription_prefix() {
    local sub_uri sub_domain sub_port sub_path
    sub_uri=$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='subURI';" 2>/dev/null) || true
    if [[ -n "$sub_uri" ]]; then
        echo "$sub_uri"
        return
    fi
    sub_domain=$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='subDomain';" 2>/dev/null) || true
    sub_port=$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='subPort';" 2>/dev/null) || true
    sub_path=$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key='subPath';" 2>/dev/null) || true
    local server_ip
    server_ip=$(curl -s4 --max-time 3 ifconfig.me 2>/dev/null) || server_ip="127.0.0.1"
    echo "https://${sub_domain:-$server_ip}:${sub_port:-2096}${sub_path:-/}"
}

# Auto-rollback helper — восстанавливает settings и рестартит x-ui после неудачи
rollback_settings() {
    local backup="$1"
    log_error "xray not listening on :443 — rolling back"
    local s_backup="${backup//\'/\'\'}"
    x-ui stop > /dev/null 2>&1 || true
    sqlite3 "$XUI_DB" "UPDATE inbounds SET settings='${s_backup}' WHERE tag='$INBOUND_TAG';"
    x-ui start > /dev/null 2>&1
}

# Health check — ждём что xray забиндил :443 после x-ui start
wait_xray_listening() {
    local _i
    for _i in 1 2 3 4 5; do
        if ss -tln 2>/dev/null | grep -q ':443 '; then return 0; fi
        sleep 1
    done
    return 1
}

cmd_add() {
    local name="${1:-}"
    if [[ -z "$name" ]]; then log_error "Usage: vpn add <name>"; exit 1; fi
    if ! [[ "$name" =~ $NAME_REGEX ]]; then
        log_error "Invalid name '$name' — only [a-zA-Z0-9_-], 1..32 chars"
        exit 1
    fi

    # Уникальность
    local existing
    existing=$(sqlite3 "$XUI_DB" "SELECT settings FROM inbounds WHERE tag='$INBOUND_TAG';" \
        | jq -r --arg name "$name" '.clients[] | select(.email == $name) | .id' 2>/dev/null) || true
    if [[ -n "$existing" ]]; then
        log_error "Client '$name' already exists (UUID $existing)"
        exit 1
    fi

    local uuid sub_id
    uuid=$(uuidgen)
    sub_id=$(head -c 8 /dev/urandom | xxd -p)

    log_info "Adding client '$name' (UUID: $uuid)"

    # Backup settings в памяти для rollback
    local backup_settings
    backup_settings=$(sqlite3 "$XUI_DB" "SELECT settings FROM inbounds WHERE tag='$INBOUND_TAG';")

    x-ui stop > /dev/null 2>&1 || true

    local new_settings
    new_settings=$(echo "$backup_settings" | jq -c \
        --arg uuid "$uuid" --arg name "$name" --arg sub_id "$sub_id" \
        '.clients += [{
            id: $uuid, flow: "", email: $name,
            limitIp: 0, totalGB: 0, expiryTime: 0,
            enable: true, subId: $sub_id, tgId: "", reset: 0
        }]')
    local s_settings="${new_settings//\'/\'\'}"
    sqlite3 "$XUI_DB" "UPDATE inbounds SET settings='${s_settings}' WHERE tag='$INBOUND_TAG';"

    sync_cdn_clients || log_warn "CDN sync failed (non-fatal)"

    x-ui start > /dev/null 2>&1

    if ! wait_xray_listening; then
        rollback_settings "$backup_settings"
        exit 2
    fi

    local prefix link
    prefix=$(get_subscription_prefix)
    link="${prefix}${sub_id}"
    log_ok "Added client '$name'"
    echo ""
    echo "Subscription: $link"
}
cmd_list() {
    local clients_json
    clients_json=$(sqlite3 "$XUI_DB" "SELECT settings FROM inbounds WHERE tag='$INBOUND_TAG';" \
        | jq -c '.clients') || {
            log_error "Cannot read clients from $XUI_DB"; exit 1
        }

    local count
    count=$(echo "$clients_json" | jq 'length')
    if [[ "$count" == 0 ]]; then
        echo "No clients."
        return
    fi

    {
        printf 'NAME\tUUID\tENABLE\tUP\tDOWN\n'
        echo "$clients_json" | jq -r '.[] | [.email, .id, (if .enable then "yes" else "no" end)] | @tsv' \
        | while IFS=$'\t' read -r email uuid enable; do
            local traffic up=0 down=0
            traffic=$(sqlite3 -separator $'\t' "$XUI_DB" \
                "SELECT up, down FROM client_traffics WHERE email='${email//\'/\'\'}';" 2>/dev/null) || true
            if [[ -n "$traffic" ]]; then
                up=$(echo "$traffic" | cut -f1)
                down=$(echo "$traffic" | cut -f2)
            fi
            local up_h down_h
            up_h=$(numfmt --to=iec --suffix=B "$up" 2>/dev/null || echo "${up}B")
            down_h=$(numfmt --to=iec --suffix=B "$down" 2>/dev/null || echo "${down}B")
            printf '%s\t%s\t%s\t%s\t%s\n' "$email" "$uuid" "$enable" "$up_h" "$down_h"
        done
    } | column -t -s$'\t'
}
cmd_link()   { log_error "not implemented yet"; exit 1; }
cmd_remove() { log_error "not implemented yet"; exit 1; }

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        add)    require_relay; cmd_add "$@" ;;
        list)   require_relay; cmd_list "$@" ;;
        link)   require_relay; cmd_link "$@" ;;
        remove) require_relay; cmd_remove "$@" ;;
        help|-h|--help) usage ;;
        *)      log_error "Unknown command: $cmd"; usage; exit 1 ;;
    esac
}

main "$@"
